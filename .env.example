BROKER_HOST=127.0.0.1
BROKER_PORT=3317
# camoufox (default, anti-detect Firefox) or chromium (legacy)
BROWSER_ENGINE=camoufox
PROFILE_DIR=/Users/samlowry/Documents/retail-perplexity-mcp/data/profile
ARTIFACTS_DIR=/Users/samlowry/Documents/retail-perplexity-mcp/data/artifacts
LOG_LEVEL=info
# Max generation wait per job in milliseconds (900000 = 900 s = 15 min). MCP uses timeout_seconds in seconds.
DEFAULT_TIMEOUT_MS=900000
HEADLESS=0
ALLOW_FILE_UPLOAD=1
ALLOW_MODEL_SWITCH=1
PERPLEXITY_URL=https://www.perplexity.ai/
CONCURRENT_REQUEST_POLICY=reject
