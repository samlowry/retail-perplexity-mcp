{
  "name": "perplexity-desktop-broker",
  "version": "0.1.0",
  "private": true,
  "description": "Local desktop broker for Perplexity web UI via Playwright",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev:broker": "pnpm --filter @pdb/broker dev",
    "dev:mcp": "pnpm --filter @pdb/mcp-server dev",
    "doctor": "pnpm --filter @pdb/doctor start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "node scripts/e2e-thread-status.mjs",
    "test:e2e:long": "SKIP_SMOKE=1 node scripts/e2e-thread-status.mjs",
    "test:e2e:smoke": "ONLY_SMOKE=1 node scripts/e2e-thread-status.mjs",
    "smoke:worker": "pnpm --filter @pdb/playwright-worker smoke",
    "camoufox:fetch": "pnpm --filter @pdb/playwright-worker exec camoufox-js fetch",
    "launchd:install": "bash scripts/install-launch-agent.sh",
    "launchd:uninstall": "bash scripts/uninstall-launch-agent.sh",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "packageManager": "pnpm@10.11.0"
}
